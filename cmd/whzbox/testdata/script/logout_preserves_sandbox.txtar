# logout should clear only the session tokens and preserve cached sandboxes.
env WHZBOX_STATE_DIR=$WORK/state

exec chmod 700 state
exec chmod 600 state/state.json

exec whzbox logout

exec whzbox status
stdout 'Session'
stdout '\(not logged in\)'

exec whzbox list
stdout 'aws'
stdout '111111111111'
stdout 'active'

exec whzbox exec aws -- /usr/bin/env
stdout 'AWS_ACCESS_KEY_ID=AKIA_LOGOUT_TEST'
stdout 'AWS_SECRET_ACCESS_KEY=logout-secret'
stdout 'AWS_REGION=us-east-1'
stdout 'AWS_DEFAULT_REGION=us-east-1'

-- state/state.json --
{
  "version": 1,
  "whizlabs": {
    "user_email": "alice@example.com",
    "access_token": "access-abc",
    "refresh_token": "refresh-def",
    "access_token_expires_at": "2099-04-11T20:00:00Z",
    "refresh_token_expires_at": "2099-04-18T20:00:00Z"
  },
  "sandboxes": {
    "aws": {
      "kind": "aws",
      "slug": "aws-sandbox",
      "verified": true,
      "credentials": {
        "access_key": "AKIA_LOGOUT_TEST",
        "secret_key": "logout-secret"
      },
      "console": {
        "url": "https://111111111111.signin.aws.amazon.com/console",
        "username": "whiz_user",
        "password": "pw"
      },
      "identity": {
        "account": "111111111111",
        "user_id": "AIDALOGOUT",
        "arn": "arn:aws:iam::111111111111:user/whiz_user",
        "region": "us-east-1"
      },
      "started_at": "2099-04-11T12:00:00Z",
      "expires_at": "2099-04-11T13:00:00Z"
    }
  }
}
